# ═══════════════════════════════════════
# Practical Khata — Environment Variables
# এই file টা NEVER Git এ push করবে না!
# .gitignore এ .env add করো
# ═══════════════════════════════════════

# ── Django Core ──────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ── Admin URL (Secret!) ───────────────
# /admin/ এ গেলে 404 দেখাবে
# এই URL টা শুধু তুমি জানবে
ADMIN_URL=AdminMozahid2026

# ── AI Keys ──────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=google/flan-t5-small

# ── Email (Optional) ─────────────────
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# ── Production only ──────────────────
# DEBUG=False
# ALLOWED_HOSTS=yourdomain.railway.app
